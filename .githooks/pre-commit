#!/bin/sh
# Run ESLint --fix on staged source files only.
# This avoids linting generated output like .next/.
echo "Running eslint --fix on staged source files..."
staged_files=$(git diff --cached --name-only --diff-filter=ACMR -- '*.js' '*.jsx' '*.ts' '*.tsx')
if [ -n "$staged_files" ]; then
  echo "$staged_files" | grep -vE '(^|/)(node_modules|\.next|dist|out|build|coverage|playwright-report|test-results)/' | xargs pnpm exec eslint --fix
  status=$?
  if [ $status -ne 0 ]; then
    echo "ESLint reported problems. Please fix them before committing."
    exit $status
  fi

  # Stage any fixes made by eslint --fix
  git add -A
fi

# Run TypeScript type-check to block commits that introduce type errors
echo "Running tsc --noEmit..."
pnpm exec tsc --noEmit
status=$?
if [ $status -ne 0 ]; then
  echo "TypeScript errors found. Please fix them before committing."
  exit $status
fi

exit 0
