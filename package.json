{
  "name": "shadcn-sidebar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:prod": "next build && concurrently \"next start -p 3000\" \"electron .\"",
    "lint": "next lint",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx . --fix",
    "lint:watch": "eslint --ext .js,.jsx,.ts,.tsx . --fix --watch",
    "lmstudio:probe": "node scripts/lmstudio-probe.js",
    "registry:build": "tsx ./scripts/build-registry.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
